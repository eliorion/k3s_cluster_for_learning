#!/bin/bash

/usr/local/bin/mise trust /workspaces/$DEVPOD_WORKSPACE_ID/mise.toml && /usr/local/bin/mise install

# Claude Code installation
curl -fsSL https://claude.ai/install.sh | bash

# RTK - token-optimizing CLI proxy (installs the Bash PreToolUse hook)
curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
rtk init -g --auto-patch

# Caveman - plugin + SessionStart/UserPromptSubmit hooks + statusline
curl -fsSL https://raw.githubusercontent.com/JuliusBrussee/caveman/main/install.sh | bash

# Graphify - install package via uv (uv provided by mise), then wire to Claude Code
uv tool install graphifyy
graphify install
